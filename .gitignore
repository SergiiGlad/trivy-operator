# Local .terraform directory
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data based configuration and not part of the main 
# configuration.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally 
# and so are not considered part of the main project configuration.
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include plugin cache directory
!*.terraform.lock.hcl

# Include terraform plan files
*.tfplan
# Python virtual environment
.venv/
__pycache__/
.DS_Store

scripts/test/

